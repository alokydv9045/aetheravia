# AETHRAVIA Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit real secrets to version control

############################################################
# Runtime / environment
NODE_ENV=development
APP_ENV=local

############################################################
# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGOOSE_DEBUG=true
MONGODB_LOG=info

############################################################
# NextAuth / session
NEXTAUTH_SECRET=your-super-secret-key-here-minimum-32-characters
NEXTAUTH_URL=http://localhost:3000

AUTH_TRUST_HOST=localhost
AUTH_DEBUG=true
SESSION_MAX_AGE=2592000
SESSION_UPDATE_AGE=86400

############################################################
# Public site / SEO
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME=AETHRAVIA
NEXT_PUBLIC_BRAND_TAGLINE="Embrace the earth, unveil your personality"
NEXT_PUBLIC_SHOP_ADDRESS="H.no. 46, Mohalla Mohammad Wasil, Near Hadri Masjid, Pilibhit, Uttar Pradesh, India, 262001"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_SUPPORT_PHONE=+91-XXXX-XXXXXX
NEXT_PUBLIC_SUPPORT_EMAIL=heukcare@gmail.com

############################################################
# Payment (Razorpay) - REQUIRED FOR PAYMENTS
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_API_URL=https://api.razorpay.com/v1

############################################################
# Cloudinary (uploads) - REQUIRED FOR IMAGE UPLOADS
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

############################################################
# SMTP / email - REQUIRED FOR EMAIL FEATURES
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
EMAIL_FROM=your-email@gmail.com

############################################################
# SMS (Twilio) - REQUIRED FOR SMS FEATURES
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

############################################################
# Caching / rate-limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token
ENABLE_RATE_LIMITING=false

############################################################
# Shipment / 3PL providers - REQUIRED FOR DELIVERY
DELIVERY_COM_API_KEY=your_delivery_com_api_key
DELIVERY_COM_BASE_URL=https://api.delivery.com
ECART_API_KEY=your_ecart_api_key
ECART_SECRET_KEY=your_ecart_secret
ECART_BASE_URL=https://api.ecart.com
SHIPPO_API_KEY=your_shippo_api_key
SHIPPO_BASE_URL=https://api.goshippo.com/v1
SHIPPO_WEBHOOK_URL=https://your-domain.com/api/webhooks/shippo
DEFAULT_3PL_PROVIDER=3PL_SHIPPO

############################################################
# Store details
STORE_NAME="AETHRAVIA Store"
STORE_PHONE=+911234567890
STORE_ADDRESS="123 Store Street"
STORE_CITY=Mumbai
STORE_STATE=Maharashtra
STORE_ZIP=400001
STORE_COUNTRY=India

############################################################
# CAPTCHA / bot protection
RECAPTCHA_SECRET_KEY=your_recaptcha_secret
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret
HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret
TURNSTILE_SITE_KEY=your_turnstile_site_key

############################################################
# Security alerts / webhooks
SECURITY_WEBHOOK_URL=https://your-webhook-url.com
SECURITY_ALERT_EMAIL=security@yourdomain.com

############################################################
# Logging / misc
LOG_LEVEL=debug
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png
MONGOOSE_DEBUG=true

############################################################
# Feature flags
ENABLE_2FA=false
ENABLE_EMAIL_VERIFICATION=false
ENABLE_LOGIN_NOTIFICATIONS=true
ENABLE_SUSPICIOUS_LOGIN_DETECTION=false

GDPR_COMPLIANCE=false
AUDIT_LOG_RETENTION_DAYS=90
REQUEST_TIMEOUT=15000
MAX_REQUEST_SIZE=1048576

FEATURE_ADMIN_DASHBOARD=true
FEATURE_SECURITY_MONITORING=false
FEATURE_ADVANCED_ANALYTICS=false

############################################################
# SETUP INSTRUCTIONS:
#
# 1. Razorpay: Sign up at https://razorpay.com and get API keys
# 2. Cloudinary: Sign up at https://cloudinary.com for image hosting
# 3. SMTP: Use Gmail App Passwords or services like SendGrid
# 4. Twilio: Sign up at https://twilio.com for SMS functionality
# 5. 3PL Providers: Get API keys from respective delivery services
# 6. NextAuth Secret: Generate a random 32+ character string
#
# For production deployment, set these in your hosting platform's environment variables